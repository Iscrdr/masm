{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-day1",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-g",
                "${workspaceFolder}/day1/*.c",
                "-o",
                "${workspaceFolder}/out/day1/a.out"
            ],
            "group": "build",
            "problemMatcher": "$gcc"
        },
